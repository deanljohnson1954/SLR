---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SavingsCard from '../components/SavingsCard.astro';
---

<BaseLayout
  title="Attorney Buyer's Agent Sonoma County | 1% Commission | Dean L. Johnson J.D."
  description="Sonoma County buyer's agent at 1% commission. Attorney Dean L. Johnson brings decades of real estate law expertise to protect your interests and save you thousands."
  keywords="attorney buyer's agent Sonoma County, attorney realtor Sonoma County first-time buyer, real estate attorney buyer representation Sonoma County, 1 percent commission buyer agent Sonoma County, attorney broker wine country home purchase, exclusive buyer agent attorney California, buy home Sonoma County legal protection"
>
    <div class="hero">
        <div class="hero-content">
            <h1>Sonoma County Real Estate Buyer's Agent<br><strong>1% Commission Fee</strong></h1>
            <p>Attorney Dean L. Johnson brings decades of real estate law expertise to protect your interests and save you thousands. Expert legal guidance through every step of your home purchase in Sonoma County wine country.</p>
            <a href="/contact/" class="cta-button" aria-label="Schedule a free consultation with Sonoma Lawyers Realty">Schedule Consultation</a>
        </div>
    </div>

    <section>
        <h2 class="section-title">Why Choose Us</h2>
        <p class="section-subtitle">Professional representation with legal expertise at a fraction of the traditional cost.</p>

        <div class="features">
            <FeatureCard
                icon="⚖️"
                title="Decades of Real Estate Law"
                description="Dean L. Johnson has specialized in all areas of real estate law for decades. With an M.B.A. and J.D., his legal expertise ensures your transaction is protected from contract to closing, with careful attention to every detail that matters."
            />
            <FeatureCard
                icon="💰"
                title="1% Commission"
                description="Keep more of your money. Save thousands compared to traditional 2.5-3% buyer's agent fees. On a $1M home, that's up to $20,000 in savings for the same professional service."
            />
            <FeatureCard
                icon="🏡"
                title="Local Knowledge"
                description="Deep expertise in Sonoma County real estate. From Healdsburg to Petaluma, we know the neighborhoods, market trends, and what makes each area special."
            />
            <FeatureCard
                icon="🤝"
                title="Buyers Only — Always"
                description="We represent buyers exclusively and never take listings or represent sellers. This means 100% loyalty to you, zero conflicts of interest, and complete confidentiality throughout your home search and purchase."
            />
        </div>
    </section>

    <section style="padding: 0; max-width: 100%; margin: 4rem 0;">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;">
            <div style="height: 400px; overflow: hidden; position: relative;">
                <img src="/photos/trent-erwin-vineyard.jpg" alt="Vineyard rows in Sonoma County wine country" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); padding: 2rem; color: white;">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; margin: 0;">Wine Country Living</h3>
                </div>
            </div>
            <div style="height: 400px; overflow: hidden; position: relative;">
                <img src="/photos/ys-bodega-bay.jpg" alt="Coastal landscape at Bodega Bay, Sonoma County" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); padding: 2rem; color: white;">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; margin: 0;">Scenic Beauty</h3>
                </div>
            </div>
            <div style="height: 400px; overflow: hidden; position: relative;">
                <img src="/photos/dan-meyers-sonoma.jpg" alt="Lavender fields in Sonoma County at golden hour" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); padding: 2rem; color: white;">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; margin: 0;">Golden Sunsets</h3>
                </div>
            </div>
        </div>
    </section>

    <section style="padding: 4rem 2rem; background: var(--cream);">
        <div style="max-width: 1000px; margin: 0 auto;">
            <h2 class="section-title" style="text-align:center;">Who We Help</h2>
            <p class="section-subtitle" style="text-align:center; margin: 0 auto 3rem;">Buyers come to us in different situations. Here are the ones we handle best.</p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">First-Time Buyers in Sonoma County</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">Buying your first home is the largest legal and financial transaction of your life. An attorney-broker reviews every contract clause, explains every disclosure, and makes sure you don't sign away rights you didn't know you had.</p>
                </div>

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">Bay Area Buyers Relocating to Wine Country</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">Buyers relocating from San Francisco or Silicon Valley know how competitive markets work — but Sonoma County has its own legal landscape: PTRA well ordinances, vacation rental regulations, and agricultural zoning. We navigate all of it.</p>
                </div>

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">Buyers Purchasing Vineyard or Rural Land</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">Rural and agricultural purchases involve water rights, well permits, soil assessments, and easements that most agents skip over. Our legal background means nothing gets past the contract stage without your full understanding.</p>
                </div>

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">Buyers Who Want Legal Protection Without Paying Extra</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">At 1% commission, you get an attorney-broker reviewing every document — the same legal protection that would cost thousands in separate legal fees — for less than a standard agent charges. That is not a compromise. It is a better deal.</p>
                </div>

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">Buyers Skeptical of Dual Agency</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">We represent buyers exclusively — we never take listings or represent sellers. No conflict of interest. No split loyalty. Your agent's only job is to get you the best outcome on your purchase.</p>
                </div>

                <div style="background: var(--white); padding: 2rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); border-top: 3px solid var(--accent);">
                    <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--primary); margin-bottom: 0.75rem;">Buyers Navigating California's New BRBC Rules</h3>
                    <p style="color: var(--text-light); line-height: 1.8; font-size: 0.95rem;">California's AB 2992 changed buyer representation agreements. We explain exactly what the BRBC means, what you're agreeing to, and how to protect yourself before you sign anything — including at open houses.</p>
                </div>

            </div>
        </div>
    </section>

    <div class="pricing-highlight">
        <h2>1% Buyer's Agent Fee</h2>
        <p>Professional representation at a fair price. Our streamlined approach and legal background mean you get exceptional service without the inflated costs of traditional agencies.</p>
    </div>

    <section style="padding: 4rem 2rem; background: var(--white);">
        <h2 class="section-title" style="text-align: center;">See Your Savings</h2>
        <p class="section-subtitle" style="text-align: center; margin: 0 auto;">Traditional buyer's agents charge 2.5% commission. Sonoma Lawyers Realty charges just 1%. Here's what that means for you:</p>

        <div style="max-width: 1000px; margin: 3rem auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
            <SavingsCard price="$1,000,000" traditional="$25,000" ours="$10,000" savings="$15,000" />
            <SavingsCard price="$2,500,000" traditional="$62,500" ours="$25,000" savings="$37,500" />
            <SavingsCard price="$5,000,000" traditional="$125,000" ours="$50,000" savings="$75,000" />
        </div>

        <div style="max-width: 800px; margin: 3rem auto; padding: 2.5rem; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); border-radius: 4px; color: var(--white); text-align: center;">
            <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; margin-bottom: 1rem;">What Could You Do With Your Savings?</h3>
            <p style="font-size: 1.1rem; line-height: 1.8; opacity: 0.95;">Use your savings for upgrades, furniture, closing costs, or simply keep more money in your pocket. That's $15,000-$75,000+ that stays with you instead of going to inflated commission fees.</p>
        </div>
    </section>

</BaseLayout>
