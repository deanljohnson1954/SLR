---
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  articleDate?: string;
}

const {
  title = "Sonoma Lawyers Realty | 1% Buyer's Agent Fee | Attorney-Owned Real Estate Services",
  description = "Attorney-owned buyer representation at 1% commission in Sonoma County. Dean L. Johnson, M.B.A., J.D. — decades of real estate law expertise.",
  keywords,
  articleDate,
} = Astro.props;

const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = `https://www.sonomalawyersrealty.com${currentPath}`;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services/", label: "Services" },
  { href: "/about/", label: "About" },
  { href: "/sonoma-county/", label: "Sonoma County" },
  { href: "/research-tools/", label: "Research Tools" },
  { href: "/media/", label: "Articles" },
  { href: "/contact/", label: "Contact" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords ?? "Sonoma County real estate, buyer's agent, 1% commission, attorney real estate broker, Dean L. Johnson, Healdsburg homes, Sonoma Valley properties, low commission buyer agent, real estate attorney, Sonoma wine country, AB 2992, BRBC, buyer broker agreement, California real estate law"}>
    <meta name="author" content="Dean L. Johnson, Attorney & Real Estate Broker">
    <meta name="robots" content="index, follow">
    <meta name="language" content="English">

    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content={articleDate ? "article" : "website"}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:site_name" content="Sonoma Lawyers Realty">
    <meta property="og:locale" content="en_US">
    {articleDate && <meta property="article:published_time" content={articleDate}>}
    {articleDate && <meta property="article:author" content="Dean L. Johnson">}

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>

    <!-- Geo-targeting -->
    <meta name="geo.region" content="US-CA">
    <meta name="geo.placename" content="Sonoma County, California">
    <meta name="geo.position" content="38.2921;-122.4580">
    <meta name="ICBM" content="38.2921, -122.4580">

    <!-- Canonical URL (unique per page — critical for SEO) -->
    <link rel="canonical" href={canonicalURL}>
    <link rel="sitemap" href="/sitemap.xml">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Schema: WebSite -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Sonoma Lawyers Realty",
        "url": "https://www.sonomalawyersrealty.com",
        "description": "Attorney-owned buyer representation at 1% commission in Sonoma County, California.",
        "publisher": {
            "@type": "Organization",
            "name": "Sonoma Lawyers Realty"
        }
    }
    </script>

    <!-- Schema: LocalBusiness + RealEstateAgent -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": ["RealEstateAgent", "LocalBusiness"],
        "name": "Sonoma Lawyers Realty",
        "legalName": "Dean L. Johnson, Inc. dba Sonoma Lawyers Realty",
        "description": "Attorney-owned buyer representation at 1% commission. Dean L. Johnson, M.B.A., J.D. provides expert legal guidance through every step of your Sonoma County home purchase.",
        "url": "https://www.sonomalawyersrealty.com",
        "telephone": "(760) 603-0022",
        "email": "deanl.johnson@gmail.com",
        "priceRange": "1% commission",
        "currenciesAccepted": "USD",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Healdsburg",
            "addressRegion": "CA",
            "postalCode": "95448",
            "addressCountry": "US"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 38.2921,
            "longitude": -122.4580
        },
        "areaServed": [
            {"@type": "City", "name": "Healdsburg", "sameAs": "https://en.wikipedia.org/wiki/Healdsburg,_California"},
            {"@type": "City", "name": "Sonoma", "sameAs": "https://en.wikipedia.org/wiki/Sonoma,_California"},
            {"@type": "City", "name": "Sebastopol", "sameAs": "https://en.wikipedia.org/wiki/Sebastopol,_California"},
            {"@type": "City", "name": "Santa Rosa", "sameAs": "https://en.wikipedia.org/wiki/Santa_Rosa,_California"},
            {"@type": "City", "name": "Petaluma", "sameAs": "https://en.wikipedia.org/wiki/Petaluma,_California"},
            {"@type": "County", "name": "Sonoma County", "sameAs": "https://en.wikipedia.org/wiki/Sonoma_County,_California"}
        ],
        "serviceType": "Exclusive Buyer Representation",
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Buyer Representation Services",
            "itemListElement": [
                {
                    "@type": "Offer",
                    "name": "Exclusive Buyer Representation",
                    "description": "Full buyer representation at 1% commission — property search, offer negotiation, due diligence, contract review, and closing support.",
                    "price": "1",
                    "priceCurrency": "USD",
                    "priceSpecification": {
                        "@type": "UnitPriceSpecification",
                        "price": "1",
                        "priceCurrency": "USD",
                        "unitCode": "P1",
                        "unitText": "percent of purchase price"
                    }
                }
            ]
        },
        "founder": {
            "@type": "Person",
            "name": "Dean L. Johnson",
            "jobTitle": "Attorney & Real Estate Broker",
            "honorificSuffix": "M.B.A., J.D.",
            "url": "https://www.sonomalawyersrealty.com/about/",
            "knowsAbout": ["Real Estate Law", "Contract Negotiation", "California Property Law", "Due Diligence", "Buyer Representation"]
        },
        "sameAs": [
            "https://www.sonomalawyersrealty.com"
        ]
    }
    </script>

    <!-- Schema: Person (Dean L. Johnson) -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Dean L. Johnson",
        "honorificSuffix": "M.B.A., J.D.",
        "jobTitle": "Attorney & Real Estate Broker",
        "description": "Attorney and real estate broker with decades of experience in California real estate law. Licensed before the U.S. Supreme Court.",
        "url": "https://www.sonomalawyersrealty.com/about/",
        "worksFor": {
            "@type": "Organization",
            "name": "Sonoma Lawyers Realty",
            "url": "https://www.sonomalawyersrealty.com"
        },
        "knowsAbout": [
            "California Real Estate Law",
            "Buyer Representation",
            "Contract Negotiation",
            "Due Diligence",
            "AB 2992",
            "BRBC",
            "Sonoma County Real Estate"
        ],
        "hasCredential": [
            {"@type": "EducationalOccupationalCredential", "name": "Juris Doctor (J.D.)"},
            {"@type": "EducationalOccupationalCredential", "name": "Master of Business Administration (M.B.A.)"},
            {"@type": "EducationalOccupationalCredential", "name": "California Real Estate Broker License"},
            {"@type": "EducationalOccupationalCredential", "name": "Admitted to Practice Before the U.S. Supreme Court"}
        ]
    }
    </script>

    <!-- Schema: FAQPage -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "What is the buyer's agent commission at Sonoma Lawyers Realty?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Sonoma Lawyers Realty charges a 1% buyer's agent commission, compared to the traditional 2.5–3% charged by most agents. On a $1 million home, that's up to $20,000 in savings."
                }
            },
            {
                "@type": "Question",
                "name": "What areas of Sonoma County does Sonoma Lawyers Realty serve?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "We serve all of Sonoma County, including Healdsburg, Sonoma Valley, Sebastopol, Santa Rosa, Petaluma, and the Sonoma Coast."
                }
            },
            {
                "@type": "Question",
                "name": "Is Sonoma Lawyers Realty attorney-owned?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Yes. Dean L. Johnson, M.B.A., J.D. is both a licensed attorney and California real estate broker with decades of real estate law experience."
                }
            },
            {
                "@type": "Question",
                "name": "Does Sonoma Lawyers Realty represent sellers?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "No. Sonoma Lawyers Realty represents buyers exclusively and never takes listings or represents sellers. The firm does not represent both sides of a transaction."
                }
            },
            {
                "@type": "Question",
                "name": "Does a buyer need to sign a BRBC before attending an open house in California?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "No. Under California's AB 2992, a BRBC (Buyer Representation and Broker Compensation agreement) is only required when a broker is acting on behalf of a buyer. A seller's agent hosting an open house represents the seller, not the buyer, so no BRBC is required to attend an open house or any seller-agent showing."
                }
            }
        ]
    }
    </script>

    <!-- Schema: Service -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Exclusive Buyer Representation at 1% Commission",
        "provider": {
            "@type": "RealEstateAgent",
            "name": "Sonoma Lawyers Realty",
            "url": "https://www.sonomalawyersrealty.com"
        },
        "serviceType": "Real Estate Buyer Representation",
        "areaServed": {
            "@type": "County",
            "name": "Sonoma County",
            "addressRegion": "CA",
            "addressCountry": "US"
        },
        "description": "Full-service buyer representation including property search, offer preparation and negotiation, due diligence review, contract analysis, and closing support — all at 1% commission.",
        "offers": {
            "@type": "Offer",
            "price": "1",
            "priceCurrency": "USD",
            "priceSpecification": {
                "@type": "UnitPriceSpecification",
                "price": "1",
                "unitText": "percent of purchase price"
            }
        }
    }
    </script>

    <!-- Article Schema (for article pages) -->
    {articleDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": articleDate,
        "author": {
          "@type": "Person",
          "name": "Dean L. Johnson",
          "jobTitle": "Attorney & Real Estate Broker",
          "url": "https://www.sonomalawyersrealty.com/about/"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Sonoma Lawyers Realty",
          "url": "https://www.sonomalawyersrealty.com"
        },
        "url": canonicalURL,
        "mainEntityOfPage": canonicalURL
      })} />
    )}

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i+"?ref=bwt";
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "w588htzd7e");
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container">
            <a href="/" class="logo">Sonoma Lawyers Realty</a>
            <button class="hamburger" id="hamburger-btn" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-links" id="nav-links">
                {navLinks.map(link => (
                    <li>
                        <a
                            href={link.href}
                            class:list={[{ 'active-nav': currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
                        >
                            {link.label}
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    </nav>

    <slot />

    <footer>
        <p>&copy; 2026 Dean L. Johnson, Inc. dba Sonoma Lawyers Realty</p>
        <p>Attorney & Real Estate Broker | Decades of Real Estate Law Experience</p>
        <p style="margin-top: 0.5rem;"><a href="https://www.sonomalawyersrealty.com" style="color: var(--accent); text-decoration: none;">www.SonomaLawyersRealty.com</a></p>
        <p style="margin-top: 1rem; font-size: 0.9rem; opacity: 0.7;">Decades of real estate law experience | 1% buyer representation fee</p>
    </footer>

    <script>
        // Hamburger toggle
        const hamburger = document.getElementById('hamburger-btn');
        const navLinks = document.getElementById('nav-links');
        if (hamburger && navLinks) {
            hamburger.addEventListener('click', () => {
                hamburger.classList.toggle('open');
                navLinks.classList.toggle('open');
            });
        }

        // Intersection Observer for feature card entrance animations
        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.feature-card').forEach(card => observer.observe(card));
    </script>
</body>
</html>
