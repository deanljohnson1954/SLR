---
interface Props {
  src: string;
  alt: string;
  title: string;
  description: string;
}

const { src, alt, title, description } = Astro.props;
---

<div class="gallery-item">
    <img src={src} alt={alt}>
    <div class="gallery-overlay">
        <h3>{title}</h3>
        <p>{description}</p>
    </div>
</div>
