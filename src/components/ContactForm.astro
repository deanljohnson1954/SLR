---

<form class="contact-form" id="contact-form">
    <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required>
    </div>

    <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" required>
    </div>

    <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" required>
    </div>

    <div class="form-group">
        <label for="timeline">Purchase Timeline</label>
        <select id="timeline" name="timeline" required>
            <option value="">Select timeline...</option>
            <option value="immediate">Ready to buy now</option>
            <option value="1-3months">1-3 months</option>
            <option value="3-6months">3-6 months</option>
            <option value="6-12months">6-12 months</option>
            <option value="exploring">Just exploring</option>
        </select>
    </div>

    <div class="form-group">
        <label for="message">Tell us about your home search</label>
        <textarea id="message" name="message" placeholder="What areas interest you? What type of property are you looking for? Any specific requirements?" required></textarea>
    </div>

    <button type="submit" class="submit-button">Schedule Consultation</button>
    <div id="form-success" class="form-success">
        ✓ Your email client will open with your message pre-filled. We'll be in touch within 24 hours!<br>
        <span style="font-weight: 400; font-size: 0.9rem;">Or reach us directly at <a href="mailto:deanL.johnson@gmail.com" style="color: #2e7d32;">deanL.johnson@gmail.com</a> or <a href="tel:+17606030022" style="color: #2e7d32;">(760) 603-0022</a></span>
    </div>
</form>

<script>
    const form = document.getElementById('contact-form');
    if (form) {
        form.addEventListener('submit', function(event) {
            event.preventDefault();
            const formEl = event.target as HTMLFormElement;
            const name = (formEl.elements.namedItem('name') as HTMLInputElement).value;
            const email = (formEl.elements.namedItem('email') as HTMLInputElement).value;
            const phone = (formEl.elements.namedItem('phone') as HTMLInputElement).value;
            const timeline = (formEl.elements.namedItem('timeline') as HTMLSelectElement).value;
            const message = (formEl.elements.namedItem('message') as HTMLTextAreaElement).value;
            const subject = `Consultation Request – ${name}`;
            const body = `Name: ${name}\nEmail: ${email}\nPhone: ${phone}\nTimeline: ${timeline}\n\nMessage:\n${message}`;
            window.open(`mailto:deanL.johnson@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`);
            const successEl = document.getElementById('form-success');
            if (successEl) successEl.classList.add('show');
            formEl.reset();
        });
    }
</script>
