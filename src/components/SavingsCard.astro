---
interface Props {
  price: string;
  traditional: string;
  ours: string;
  savings: string;
}

const { price, traditional, ours, savings } = Astro.props;
---

<div style="background: var(--cream); padding: 2.5rem; border-radius: 4px; box-shadow: 0 4px 20px var(--shadow); text-align: center;">
    <div style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; color: var(--primary); font-weight: 600; margin-bottom: 1rem;">{price}</div>
    <div style="font-size: 1.1rem; color: var(--text-light); margin-bottom: 1.5rem;">Purchase Price</div>
    <div style="border-top: 2px solid var(--accent); padding-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem; color: var(--text-light);">
            <span>Traditional 2.5%:</span>
            <span style="font-weight: 600;">{traditional}</span>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; color: var(--primary); font-weight: 600;">
            <span>Sonoma Lawyers Realty 1%:</span>
            <span>{ours}</span>
        </div>
        <div style="background: var(--accent); color: var(--primary-dark); padding: 1rem; border-radius: 4px; font-weight: 600; font-size: 1.2rem;">
            You Save: {savings}
        </div>
    </div>
</div>
